# Application
NODE_ENV=development
PORT=4000
API_PREFIX=/api

# MongoDB
MONGODB_URI=mongodb://localhost:27017/deskscreentime

# JWT
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=7d

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# SMTP (mail features)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_EMAIL_FROM=no-reply@example.com

# Storage paths
SCREENSHOT_STORAGE_ROOT=./public/screenshots
EXTENSION_SCREENSHOT_ROOT=./public/extensions-screenshot

# Frontend / public asset URLs
PUBLIC_IMAGE_BASE_URL=http://localhost:4000
PUBLIC_UPLOAD_URL=http://localhost:4000

# Encryption (for helpers)
CRYPTO_ENCRYPTION_KEY=replace-with-an-encryption-key
